{
  "name": "@gambi97/pier-cli",
  "version": "0.1.7",
  "description": "One command from zero to working authentication for a keel-fleet app: Clerk application, secrets in Infisical, Next.js scaffold. Only Node required.",
  "keywords": [
    "pier",
    "keel",
    "clerk",
    "authentication",
    "nextjs",
    "scaffold"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gambi97/pier.git"
  },
  "homepage": "https://github.com/Gambi97/pier#readme",
  "bugs": {
    "url": "https://github.com/Gambi97/pier/issues"
  },
  "type": "module",
  "bin": {
    "pier": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
